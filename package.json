{
  "name": "opencode-session-manager",
  "version": "1.0.0",
  "description": "OpenCode plugin: pin, backup, restore, auto-cleanup sessions — protects sessions across reinstalls.",
  "type": "module",
  "main": "dist/plugin.js",
  "types": "dist/plugin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && bun build session-manager.ts --outfile dist/plugin.js --target node --format esm --external @opencode-ai/plugin"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "session",
    "backup",
    "memory",
    "agent"
  ],
  "author": "EnerJizeIT",
  "repository": { "type": "git", "url": "https://github.com/EnerJizeIT/opencode-session-manager.git" },
  "homepage": "https://github.com/EnerJizeIT/opencode-session-manager#readme",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/bun": "^1.3.8"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "session.idle",
      "session.deleted"
    ]
  },
  "files": [
    "dist",
    "package.json"
  ]
}
